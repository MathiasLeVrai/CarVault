@startuml packages
title CarVault — Diagramme de paquets (organisation monorepo)

skinparam packageStyle folder

package "CarVault (monorepo)" {

  package "frontend" {
    package "src" {
      package "pages" as FPages {
        [Login / Register / Reset]
        [Dashboard]
        [Vehicles / VehicleDetail]
        [Documents / Expenses]
        [FuelTracker / Mileage]
        [Alerts]
        [MapPage]
        [Settings / Pricing]
        [SharePage (public)]
      }
      package "components" as FComp {
        package "ui" { [Button, Card, Modal,\nInput, Toast] }
        package "dashboard" { [FuelPriceWidget,\nBadgesWidget,\nQuickActionSheet] }
        package "vehicle" { [VehicleHero,\nHealthCard,\nMaintenancePlan,\nValuation] }
        [OnboardingTour]
        [PremiumModal]
        [PlateScanModal]
      }
      package "context" as FCtx { [AuthContext] \n[ThemeContext]\n[ToastContext] }
      package "services" as FSvc { [api.js — ApiClient] }
      package "hooks" as FHooks
    }
    [index.html]
    [vite.config.js]
    [tailwind.config.js]
  }

  package "backend" {
    package "src" {
      package "routes" as BRoutes
      package "controllers" as BCtrl {
        [auth, vehicle, document,\nexpense, fuel, alert,\nmileage, badge, dashboard,\nnotification, share,\nsubscription]
      }
      package "services" as BSvc {
        [auth, vehicle, document,\nexpense, fuel, alert,\nhealth, dashboard, badge,\nnotification, share,\nstripe, email, pdf, push,\nstorage, carapi, plate,\ncritair, fuel-price]
      }
      package "middleware" as BMW {
        [auth.middleware]
        [error.middleware]
        [upload.middleware]
        [rate-limit]
      }
      package "cron" as BCron {
        [alert.cron]
        [weekly-digest.cron]
        [monthly-report.cron]
        [budget.cron]
        [engagement.cron]
      }
      package "utils" as BUtils { [AppError, logger] }
      [index.js]
    }
    package "prisma" {
      [schema.prisma]
      [migrations/]
    }
  }

  package "docs" {
    [design-system/]
  }

  [fly.toml]
  [Dockerfile]
  [.github/workflows]
}

FPages ..> FComp
FPages ..> FCtx
FPages ..> FSvc
FSvc ..> BRoutes : HTTP/JSON

BRoutes ..> BCtrl
BCtrl ..> BSvc
BCtrl ..> BMW
BSvc ..> "prisma"
BCron ..> BSvc

@enduml
