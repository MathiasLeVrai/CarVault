@startuml deployment
title CarVault — Diagramme de déploiement

skinparam nodesep 20
skinparam ranksep 40

node "Appareil utilisateur" as Device {
  artifact "PWA CarVault\n(React 19 build)" as PWA
  artifact "Service Worker" as SW
}

cloud "Internet / HTTPS" as Net

node "Fly.io — région CDG" <<datacenter>> as Fly {
  node "Machine fly.io\n(Docker)" as FlyVM {
    artifact "Node.js 20\n+ Express API" as API
    artifact "node-cron\n(jobs 6h)" as Crons
  }
  node "Volume persistant\n/data" as Volume {
    artifact "documents/*.pdf\n*.jpg" as Files
  }
}

node "Neon (AWS eu-west)" <<dbaas>> as Neon {
  database "PostgreSQL 16\n(serverless)" as PG
}

node "Stripe" <<saas>> as StripeNode {
  artifact "Checkout + Billing\nPortal" as StripeApp
  artifact "Webhook\nendpoint" as Webhook
}

node "Resend / SMTP" <<saas>> as Mail {
  artifact "Email transactionnel\n+ digests" as MailApp
}

node "Services tiers (publics)" <<external>> as Ext {
  artifact "data.economie\n.gouv.fr" as GovAPI
  artifact "Overpass API\n(OSM)" as OSM
  artifact "RapidAPI\nCarAPI" as CarAPI
  artifact "LaCentrale\n(cote)" as Cote
  artifact "Web Push\n(VAPID)" as Push
}

node "GitHub" <<devops>> as GH {
  artifact "Actions CI/CD\n(lint + build + deploy)" as CI
}

Device -down-> Net
Net -down-> FlyVM : HTTPS 443\nJWT Bearer
PWA -right-> OSM : HTTPS (direct)
SW -right-> Push : HTTPS

FlyVM -down-> PG : TCP 5432 TLS
FlyVM -right-> Volume : mount /data
FlyVM -right-> StripeApp : API REST
Webhook -left-> FlyVM : POST /subscription/webhook
FlyVM --> MailApp : SMTP / HTTPS
FlyVM --> GovAPI : HTTPS (cache 1h)
FlyVM --> CarAPI : HTTPS
FlyVM --> Cote : HTTPS
FlyVM --> Push : HTTPS

CI ==> FlyVM : flyctl deploy
CI ==> PWA : static build

@enduml
