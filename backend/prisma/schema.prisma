generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notifEmail  Boolean @default(true)
  notifPush   Boolean @default(false)
  notifWeekly Boolean @default(true)

  isPremium            Boolean  @default(false)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  premiumExpiresAt     DateTime?

  vehicles       Vehicle[]
  alerts         Alert[]
  shareLinks     ShareLink[]
  bankConnection BankConnection?

  @@map("users")
}

model Vehicle {
  id            String   @id @default(uuid())
  brand         String
  model         String
  year          Int
  mileage       Int      @default(0)
  photo         String?
  licensePlate  String?
  color         String?
  fuelType      FuelType @default(GASOLINE)
  purchasePrice Float?
  carapiTrimId  Int?
  msrp          Float?
  horsepower    Int?
  engineSize    Float?
  transmission  String?
  bodyType      String?
  doors         Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  documents      Document[]
  expenses       Expense[]
  mileageEntries MileageEntry[]
  fuelEntries    FuelEntry[]
  shareLinks     ShareLink[]

  @@map("vehicles")
}

model Document {
  id             String       @id @default(uuid())
  name           String
  type           DocumentType
  filePath       String
  fileName       String
  expirationDate DateTime?
  notes          String?
  reminderDays   Int[]        @default([30, 7])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  vehicleId      String
  vehicle        Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("documents")
}

model Expense {
  id          String          @id @default(uuid())
  amount      Float
  category    ExpenseCategory
  date        DateTime
  description String?
  mileage     Int?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  vehicleId   String
  vehicle     Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

model Alert {
  id           String    @id @default(uuid())
  title        String
  message      String
  type         AlertType
  isRead       Boolean   @default(false)
  dueDate      DateTime?
  snoozedUntil DateTime?
  emailSent    Boolean   @default(false)
  createdAt    DateTime  @default(now())

  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("alerts")
}

model MileageEntry {
  id        String   @id @default(uuid())
  mileage   Int
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())

  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("mileage_entries")
}

enum DocumentType {
  INSURANCE
  TECHNICAL_INSPECTION
  INVOICE
  WARRANTY
  REGISTRATION
  OTHER
}

enum ExpenseCategory {
  MAINTENANCE
  TIRES
  FUEL
  INSURANCE
  REPAIR
  PARKING
  TOLL
  OTHER
}

enum AlertType {
  DOCUMENT_EXPIRY
  MAINTENANCE_DUE
  INSPECTION_DUE
  INSURANCE_RENEWAL
  OIL_CHANGE
  TIRE_SEASON
  MILEAGE_SERVICE
  OTHER
}

enum FuelType {
  GASOLINE
  DIESEL
  HYBRID
  ELECTRIC
  LPG
  OTHER
}

model FuelEntry {
  id            String   @id @default(uuid())
  date          DateTime
  mileage       Int
  liters        Float
  pricePerLiter Float
  totalCost     Float
  isFull        Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())

  vehicleId     String
  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, date])
  @@map("fuel_entries")
}

model BankConnection {
  id            String   @id @default(uuid())
  userId        String   @unique
  institutionId String
  institutionName String
  requisitionId String   @unique
  accountId     String?
  status        String   @default("pending") // pending | linked | error
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bank_connections")
}

model ShareLink {
  id        String    @id @default(uuid())
  token     String    @unique @default(uuid())
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  vehicleId String
  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("share_links")
}
