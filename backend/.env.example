# --- Sentry (monitoring backend) ---
SENTRY_DSN=""
# Optionnel : release (ex. commit SHA en CI)
SENTRY_RELEASE=""

DATABASE_URL="postgresql://user:password@host:5432/carvio?sslmode=require"
JWT_SECRET="change-this-in-production"
JWT_EXPIRES_IN="7d"
PORT=3001
UPLOAD_DIR="./uploads"
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""
CARAPI_TOKEN="your-carapi-token"
CARAPI_SECRET="your-carapi-secret"
# Origines web + apps natives Capacitor separees par des virgules.
CORS_ORIGIN="https://carvio.fr,capacitor://localhost,ionic://localhost"

# SWAGGER_ENABLED="false"

# --- EMAIL (mot de passe oublié) : 2 règles simples ---
#
# 1) Lien dans le mail = même adresse que ton site (sinon le bouton ne marche pas).
#    Exemple en local :
APP_URL="http://localhost:5173"
#
# 2) SMTP — le serveur se connecte à cette boîte pour ENVOYER les mails.
#    SMTP_USER n’est PAS l’email du visiteur : le reset part vers l’email saisi par l’utilisateur.
#    Port 465 = SSL implicite (le code fait `secure: port === 465`).
#    Ne jamais committer de vrais identifiants : uniquement Fly secrets / .env local.
#
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Adresse qui reçoit les idées envoyées depuis Réglages → Proposer une idée.
FEEDBACK_EMAIL="contact@carvio.fr"

# --- RevenueCat (abonnements iOS / In-App Purchase) ---
# Secret API key (Project Settings > API keys) — backend uniquement
REVENUECAT_SECRET_API_KEY=""
# Entitlement créé dans RevenueCat (défaut: premium)
REVENUECAT_ENTITLEMENT_ID="premium"
# Authorization header configuré dans RevenueCat > Webhooks
REVENUECAT_WEBHOOK_AUTH=""
