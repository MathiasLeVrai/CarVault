SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="CarVault <noreply@carvault.app>"
APP_URL="https://carvault.fly.dev"
