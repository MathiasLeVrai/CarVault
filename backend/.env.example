# --- Sentry (monitoring backend) ---
SENTRY_DSN=""
# Optionnel : release (ex. commit SHA en CI)
SENTRY_RELEASE=""

DATABASE_URL="postgresql://user:password@host:5432/carvio?sslmode=require"
JWT_SECRET="change-this-in-production"
JWT_EXPIRES_IN="7d"
PORT=3001
UPLOAD_DIR="./uploads"
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""
CARAPI_TOKEN="your-carapi-token"
CARAPI_SECRET="your-carapi-secret"
# Origines web + apps natives Capacitor separees par des virgules.
CORS_ORIGIN="https://carvio.fr,capacitor://localhost,ionic://localhost"

# SWAGGER_ENABLED="false"

# --- EMAIL (mot de passe oublié) : 2 règles simples ---
#
# 1) Lien dans le mail = même adresse que ton site (sinon le bouton ne marche pas).
#    Exemple en local :
APP_URL="http://localhost:5173"
#
# 2) Resend « onboarding » ne peut PAS envoyer à tous les utilisateurs.
#    Solution : envoyer avec Gmail (gratuit) en remplissant les 5 lignes ci-dessous.
#    Mot de passe Gmail = « mot de passe d’application » (pas ton mot de passe habituel).
#    Comment le créer : https://support.google.com/accounts/answer/185833
#
#    IMPORTANT — SMTP_USER n’est PAS l’email que l’utilisateur tape sur « mot de passe oublié ».
#    C’est le compte Gmail avec lequel ton SERVEUR se connecte pour ENVOYER les mails (identifiants).
#    Celui qui reçoit le reset, c’est toujours l’email de l’utilisateur (celui enregistré dans l’app).
#
RESEND_API_KEY=""
RESEND_FROM="Carvio <onboarding@resend.dev>"

SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="compte-qui-envoie@gmail.com"
SMTP_PASS="abcdefghijklmnop"
SMTP_FROM="Carvio <compte-qui-envoie@gmail.com>"
