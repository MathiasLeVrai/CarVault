DATABASE_URL="postgresql://user:password@host:5432/carvault?sslmode=require"
JWT_SECRET="change-this-in-production"
JWT_EXPIRES_IN="7d"
PORT=3001
UPLOAD_DIR="./uploads"
CARAPI_TOKEN="your-carapi-token"
CARAPI_SECRET="your-carapi-secret"
CORS_ORIGIN="https://your-app.fly.dev"

# Email (optionnel — notifications J-30/J-7/J-1)
