# Copier vers .env.docker pour personnaliser le lancement Docker Compose.
# cp .env.docker.example .env.docker

# Port exposé sur la machine hôte
APP_PORT=8080

# URL publique de l'app (liens email, reset password)
APP_URL=http://localhost:8080
CORS_ORIGIN=http://localhost:8080

# Secret JWT — changer en production
JWT_SECRET=docker-dev-secret-change-me

# Swagger UI (true/false)
SWAGGER_ENABLED=true

# --- Optionnel : APIs tierces ---
# RAPIDAPI_KEY=
# CARAPI_TOKEN=
# CARAPI_SECRET=

# --- Optionnel : emails ---
# SMTP_HOST=
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
